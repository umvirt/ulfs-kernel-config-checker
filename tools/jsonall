if [[ $1 == "" ]]
then

    echo "Error: Checks set is not defined!"
    echo
    echo "Available checks sets:"
    echo

    for s in `cd checks && ls`; do

        echo $s

    done

    exit

fi

echo "{\"set\":\"$1\",\"checks\":["

for s in `cd checks/$1 && ls` ; do

    bash tools/json $1 $s 
    echo -e ","

done

echo -e "]}"
